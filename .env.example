# Database (Aurora Serverless v2 PostgreSQL)
DATABASE_URL=postgresql://agentstarter_admin:PASSWORD@agentstarter-db.cluster-cwb60oa6m5uy.us-east-1.rds.amazonaws.com:5432/agentstarter

# Redis (ElastiCache Serverless)
REDIS_URL=rediss://your-elasticache-endpoint.serverless.use1.cache.amazonaws.com:6379

# S3 (Image Uploads)
S3_BUCKET=agentstarter-uploads
AWS_REGION=us-east-1

# Auth
NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=https://clawstarter.app  # production
NEXTAUTH_URL=http://localhost:3000

# Platform config
PLATFORM_WALLET=0x...

# Chain (Base mainnet — override for testnet)
# All chain config is in packages/shared/src/config.ts
# CONTRACT_ADDRESS is set after deployment
CONTRACT_ADDRESS=0x...
